# 八字計算器配置範本
# 複製此文件為 .env 並根據需要修改

# =============================================
# 應用配置
# =============================================
BAZI_APP_NAME=八字計算器
BAZI_APP_VERSION=1.0.0
BAZI_DEBUG=false

# 服務器配置
BAZI_HOST=127.0.0.1
BAZI_PORT=8080

# 八字計算配置
BAZI_DEFAULT_LONGITUDE=120.0
BAZI_BIRTH_YEAR_MIN=1900
BAZI_BIRTH_YEAR_MAX=2100

# =============================================
# 格局判斷配置
# =============================================
# 分析開關
GEJU_ENABLE_SHI_SHEN_PERSONALITY=true
GEJU_ENABLE_BING_YUAN=true
GEJU_ENABLE_GONG_WEI=true
GEJU_ENABLE_DAYUN_LIUNIAN=true

# 規則開關
GEJU_ENABLE_SPECIAL_CONDITIONS=true
GEJU_ENABLE_GENQI_BEIKE_CHECK=true
GEJU_SHISHEN_PERSONALITY_CONSIDER_SHENWANG=true
GEJU_DAYUN_LIUNIAN_CHECK_SPECIAL_CONDITION=true

# 顯示控制
GEJU_MAX_DAYUN_DISPLAY=10
GEJU_MAX_LIUNIAN_DISPLAY=100
